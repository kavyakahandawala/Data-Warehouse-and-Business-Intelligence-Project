      <Kpis>
        <Kpi>
          <ID>KPI</ID>
          <Name>Profit Performance KPI</Name>
          <AssociatedMeasureGroupID>Fact Sales</AssociatedMeasureGroupID>
          <Value>[Measures].[Profit]</Value>
          <Goal>500000</Goal>
          <Status>CASE
WHEN [Measures].[Profit] &gt;= 500000 THEN 1
WHEN [Measures].[Profit] &gt;= 300000 THEN 0
ELSE -1
END</Status>
          <Trend>1</Trend>
          <TrendGraphic>Standard Arrow</TrendGraphic>
          <StatusGraphic>Gauge - Ascending</StatusGraphic>
        </Kpi>
